{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sotto",
  "version": "0.1.0",
  "identifier": "app.sotto.desktop",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "overlay",
        "url": "overlay.html",
        "width": 260,
        "height": 120,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "focus": false,
        "visible": false
      },
      {
        "label": "settings",
        "url": "settings.html",
        "title": "Sotto — Settings",
        "width": 580,
        "height": 720,
        "minWidth": 548,
        "minHeight": 480,
        "decorations": false,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"],
    "resources": [
      "D:/sotto/onnxruntime.dll",
      "D:/sotto/models/parakeet-tdt-0.6b-v3-int8/**/*",
      "D:/sotto/runtime/**/*"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": false,
        "compression": "none"
      }
    }
  }
}
