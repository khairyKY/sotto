{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sotto",
  "version": "0.1.10",
  "identifier": "app.sotto.desktop",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "overlay",
        "url": "overlay.html",
        "width": 280,
        "height": 120,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "focus": false,
        "visible": false
      },
      {
        "label": "settings",
        "url": "index.html",
        "title": "Sotto",
        "width": 980,
        "height": 700,
        "minWidth": 760,
        "minHeight": 520,
        "decorations": false,
        "resizable": true,
        "center": true,
        "visible": false
      },
      {
        "label": "menu",
        "url": "menu.html",
        "width": 230,
        "height": 380,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "focus": true,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "installerHooks": "nsis/hooks.nsi"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/khairyKY/sotto/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI2MEI3OURGNDc5RjFEOTIKUldTU0haOUgzM2tMSmtLWndlQTJLTG9xUVVZWEdibVZZOUhWM3RpVXUxVmh2VSt2TFZlQXpDcFUK"
    }
  }
}
